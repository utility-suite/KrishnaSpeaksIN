        <source><x id="START_EMPHASISED_TEXT" ctype="x-em" equiv-text="&lt;em&gt;"/>KrishnaSpeaks.IN<x id="CLOSE_EMPHASISED_TEXT" ctype="x-em" equiv-text="&lt;/em&gt;"/> is where all of that comes together — as notes from the journey, shared one post at a time. </source>
        <context-group purpose="location">
          <context context-type="sourcefile">src/app/pages/about/about.component.html</context>
          <context context-type="linenumber">40,43</context>
        </context-group>
